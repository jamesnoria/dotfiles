[core]
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[delta]
  wrap-max-lines = 2
  line-numbers = true
  side-by-side = true
  syntax-theme = Dracula
  navigate = true
  dark = true
  minus-style = syntax "#3f2d3d"
  plus-style = syntax "#2d3f2f"
  zero-style = syntax
  hunk-header-style = file line-number syntax
